# ============================================================
#  Copia este archivo como  .env  y rellena los valores.
# ============================================================

# Token del bot.
#   Discord Developer Portal -> tu App -> pestana "Bot" -> "Reset Token" -> copiar.
DISCORD_TOKEN=

# ID de tu servidor "Resident Evil {Palmon Survival}".
#   En Discord: Ajustes de usuario -> Avanzado -> activar "Modo desarrollador".
#   Luego clic derecho sobre el icono del servidor -> "Copiar ID del servidor".
GUILD_ID=

# (OPCIONAL) Si quieres que el bot solo trabaje en UN canal, pon su ID aqui.
#   Clic derecho sobre el canal -> "Copiar ID del canal".
#   Si lo dejas vacio, el bot traduce en todos los canales donde pueda leer.
CHANNEL_ID=

# Idiomas a los que SIEMPRE se traduce (ademas de los que cada persona
# elija con el comando /idioma). Codigos ISO separados por coma.
TARGET_LANGS=es,en

# (OPCIONAL) Para traduccion de mayor calidad, pon aqui tu API key de DeepL
# (plan gratis: 500.000 caracteres/mes en https://www.deepl.com/pro-api).
# Si lo dejas vacio, se usa el traductor libre de Google (sin API key).
DEEPL_API_KEY=
